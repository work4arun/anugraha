# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://rathinam:rathinam@localhost:5432/mydayone"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── File Storage ─────────────────────────────────────────────────────────────
# Option A: Local disk (default for dev) — set STORAGE_PROVIDER=local
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="./uploads"

# Option B: S3-compatible (MinIO locally, AWS/Cloudflare R2 in prod)
# STORAGE_PROVIDER="s3"
# S3_ENDPOINT="http://localhost:9000"         # MinIO local endpoint
# S3_REGION="us-east-1"
# S3_BUCKET="mydayone"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"
# S3_PUBLIC_URL="http://localhost:9000/mydayone"

# ─── PDF Generation ──────────────────────────────────────────────────────────
# Puppeteer will use bundled Chromium by default.
# Override if running in a restricted environment:
# PUPPETEER_EXECUTABLE_PATH="/usr/bin/chromium-browser"

# ─── Signature OTP / SMS ──────────────────────────────────────────────────────
# Salt for hashing signature OTPs (falls back to NEXTAUTH_SECRET if unset).
OTP_SECRET="replace-with-a-secure-random-string"
#
# SMS gateway used to deliver the signature OTP. Leave SMS_PROVIDER unset in
# local dev — the OTP is then logged to the server console AND returned to the
# UI so you can test without a gateway. Set one provider for production:
#
# SMS_PROVIDER="msg91"        # or "fast2sms" or "twilio"
#
# MSG91:
# MSG91_AUTH_KEY=""
# MSG91_SENDER_ID=""
# MSG91_TEMPLATE_ID=""        # MSG91 Flow template with an {{OTP}} variable
#
# Fast2SMS:
# FAST2SMS_API_KEY=""
#
# Twilio:
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM="+1..."

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
APP_URL="http://localhost:3000"

# Admin seed credentials (used in prisma/seed.ts only — change after first login)
SEED_ADMIN_EMAIL="admin@rathinam.in"
SEED_ADMIN_PASSWORD="Admin@1234"
